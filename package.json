    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.545.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.28",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.6",
    "react-day-picker": "^9.11.1",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.65.0",
