    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "dotenv-expand": "^13.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.6",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.1.10",
    "tsx": "^4.22.1",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5.9.3"
